{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "outDir": "dist-lib",
    "rootDir": "src",
    "module": "ESNext",
    "moduleResolution": "bundler"
  },
  "include": [
    "src/control",
    "src/gestures",
    "src/filters",
    "src/tracking",
    "src/util",
    "src/config"
  ],
  "exclude": [
    "src/main.ts",
    "src/scene",
    "src/debug",
    "src/calibration",
    "src/interaction"
  ]
}
